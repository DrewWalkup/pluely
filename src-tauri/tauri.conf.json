{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nyx",
	"version": "0.2.0",
	"identifier": "com.drewwalkup.nyx",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "Nyx - AI Assistant",
				"width": 600,
				"height": 54,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": false,
				"resizable": false,
				"visibleOnAllWorkspaces": true,
				"skipTaskbar": true,
				"visible": true,
				"center": false,
				"contentProtected": true,
				"focus": false,
				"acceptFirstMouse": true,
				"shadow": false
			}
		],
		"security": { "csp": null }
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": false,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["info.plist", "nyx.desktop"],
		"macOS": { "minimumSystemVersion": "10.13" }
	},
	"plugins": {
		"sql": {
			"preload": ["sqlite:nyx.db"]
		}
	}
}
